---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { navBarLinks, identity, socialLinks } from "../config";
import type { SEOInfo } from "../types/config";

interface Props {
  seo: SEOInfo;
}

const { seo } = Astro.props;
---

<script>
  const themeToggle = document.getElementById("theme-toggle") as HTMLButtonElement;
  const html = document.documentElement;

  const currentTheme = localStorage.getItem("theme") || "dark";
  html.setAttribute("data-theme", currentTheme);

  themeToggle?.addEventListener("click", () => {
    const next = html.getAttribute("data-theme") === "dark" ? "light" : "dark";
    html.setAttribute("data-theme", next);
    localStorage.setItem("theme", next);
  });

  const btn = document.getElementById("link-menu-button") as HTMLButtonElement;
  const menu = document.getElementById("link-menu") as HTMLDivElement;

  btn?.addEventListener("click", () => {
    const hidden = menu.classList.contains("opacity-0");
    menu.classList.toggle("opacity-0", !hidden);
    menu.classList.toggle("pointer-events-none", !hidden);
  });

  document.addEventListener("click", (e) => {
    const t = e.target as Node;
    if (!btn.contains(t) && !menu.contains(t)) {
      menu.classList.add("opacity-0", "pointer-events-none");
    }
  });
</script>

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={seo.image} />
    <script is:inline>
      const t = localStorage.getItem("theme") || "dark";
      document.documentElement.setAttribute("data-theme", t);
    </script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-0KL7Y7MZKN"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-0KL7Y7MZKN');
    </script>
  </head>

  <body>
    <!-- Nav -->
    <header class="nav sticky top-0 z-50">
      <div class="nav-inner max-w-4xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 group">
          <div class="relative w-6 h-6 flex-shrink-0">
            <Image src="/logo-light.svg" alt="logo" width={24} height={24} class="logo-light w-6 h-6" />
            <Image src="/logo-dark.svg"  alt="logo" width={24} height={24} class="logo-dark  absolute inset-0 w-6 h-6" />
          </div>
          <span class="nav-brand text-sm font-semibold tracking-tight">{identity.name}</span>
        </a>

        <nav class="hidden sm:flex items-center gap-0.5 ml-auto mr-3">
          {navBarLinks.map((l) => (
            <a class="nav-link px-3 py-1.5 rounded-md text-sm font-medium" href={l.url} target={l.external ? "_blank" : "_self"}>
              {l.title}
            </a>
          ))}
        </nav>

        <div class="flex items-center gap-1">
          <button id="theme-toggle" class="nav-link p-2 rounded-md" aria-label="Toggle theme">
            <Icon name="mdi:theme-light-dark" width={15} height={15} />
          </button>
          <!-- Mobile menu -->
          <div class="relative sm:hidden">
            <button id="link-menu-button" class="nav-link px-3 py-1.5 rounded-md text-sm font-medium">Menu</button>
            <div id="link-menu" class="dropdown absolute right-0 mt-2 w-40 rounded-lg border p-1 opacity-0 pointer-events-none transition-opacity z-50">
              {navBarLinks.map((l) => (
                <a class="nav-link block px-3 py-2 rounded-md text-sm font-medium" href={l.url} target={l.external ? "_blank" : "_self"}>
                  {l.title}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </header>

    <main class="mb-32">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="footer border-t">
      <div class="max-w-4xl mx-auto px-6 py-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
        <div class="flex items-center gap-2.5">
          <div class="relative w-5 h-5">
            <Image src="/logo-light.svg" alt="logo" width={20} height={20} class="logo-light w-5 h-5" />
            <Image src="/logo-dark.svg"  alt="logo" width={20} height={20} class="logo-dark  absolute inset-0 w-5 h-5" />
          </div>
          <span class="footer-brand text-sm font-medium">{identity.name}</span>
          <span class="footer-sep text-sm">·</span>
          <span class="footer-copy text-sm">© {new Date().getFullYear()}</span>
        </div>

        <div class="flex items-center gap-1">
          {socialLinks.map((l) => (
            <a href={l.url} target={l.external ? "_blank" : "_self"} rel={l.external ? "noopener noreferrer" : undefined}
               class="footer-icon p-2 rounded-md transition-colors" aria-label={l.title}>
              <Icon name={l.icon} width={16} height={16} />
            </a>
          ))}
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&display=swap");

  /* ─── Tokens ─── */
  /*
   * Palette derived from the brand photo:
   *   Deep navy  #070c27  — photo background (dark mode page bg)
   *   Brand navy #0d1442  — nav / footer
   *   Cyan       #5bd4ea  — cloud logo accent → links & highlights
   */
  :root {
    /* Light mode — clean white with navy/blue tints */
    --bg:          #ffffff;
    --bg-subtle:   #f2f5ff;
    --bg-raised:   #e6ebff;
    --border:      #cdd5f0;
    --border-hi:   #a8b6e0;
    --text:        #070c27;   /* photo bg = darkest text */
    --text-2:      #1c2760;
    --text-3:      #4a5a99;
    --text-4:      #8090c0;
    --link:        #0b5cc8;   /* accessible blue on white */
    --link-hover:  #0848a8;
    --nav-bg:      #0d1442;
    --nav-text:    rgba(180,200,255,0.65);
    --nav-text-hi: #ffffff;
    --nav-hover:   rgba(255,255,255,0.08);
    --nav-border:  rgba(255,255,255,0.09);
  }

  [data-theme="dark"] {
    /* Dark mode — matches the photo's own background exactly */
    --bg:          #070c27;
    --bg-subtle:   #0c1235;
    --bg-raised:   #131c4a;
    --border:      #1e2960;
    --border-hi:   #2e4088;
    --text:        #eef1ff;   /* near-white, clearly readable */
    --text-2:      #c4cef4;   /* light steel blue — readable */
    --text-3:      #9aaae0;   /* readable for body copy */
    --text-4:      #6878b8;   /* secondary labels — still readable */
    --link:        #5bd4ea;   /* cyan from the cloud logo */
    --link-hover:  #8de3f4;
    --nav-bg:      #050920;
    --nav-text:    rgba(180,200,255,0.85);
    --nav-text-hi: #eef1ff;
    --nav-hover:   rgba(255,255,255,0.07);
    --nav-border:  rgba(255,255,255,0.08);
  }

  /* ─── Reset ─── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    font-family: "Inter", system-ui, -apple-system, sans-serif;
    font-feature-settings: "cv11", "ss01";
    background: var(--bg);
    color: var(--text);
    font-size: 15px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    scroll-behavior: smooth;
  }

  body { background: var(--bg); min-height: 100vh; }

  a, button { transition: color 0.12s, background 0.12s, border-color 0.12s, opacity 0.12s; }

  /* ─── Nav ─── */
  .nav {
    background: var(--nav-bg);
    border-bottom: 1px solid var(--nav-border);
    backdrop-filter: blur(12px);
  }

  .nav-brand { color: var(--nav-text-hi); }

  .nav-link {
    color: var(--nav-text);
    cursor: pointer;
    background: none;
    border: none;
  }
  .nav-link:hover { color: var(--nav-text-hi); background: var(--nav-hover); }

  .dropdown {
    background: var(--nav-bg);
    border-color: var(--nav-border);
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
  }

  /* Logo switching */
  .logo-dark  { display: none; }
  .logo-light { display: block; }
  [data-theme="dark"] .logo-dark  { display: block; }
  [data-theme="dark"] .logo-light { display: none; }

  /* Nav logos always shown on dark bg → invert light variant */
  .nav    .logo-light { filter: brightness(0) invert(1) opacity(0.9); }
  .footer .logo-light { filter: brightness(0) invert(1) opacity(0.7); }
  [data-theme="dark"] .nav    .logo-light { filter: none; }
  [data-theme="dark"] .footer .logo-light { filter: none; }

  /* ─── Footer ─── */
  .footer { background: var(--nav-bg); border-color: var(--nav-border); }
  .footer-brand { color: var(--nav-text-hi); }
  .footer-sep, .footer-copy { color: var(--nav-text); }
  .footer-icon { color: var(--nav-text); }
  .footer-icon:hover { color: var(--nav-text-hi); background: var(--nav-hover); }

  /* ─── Typography ─── */
  h1, h2, h3, h4, h5 {
    color: var(--text);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
  }

  p { color: var(--text-3); line-height: 1.7; }

  /* ─── Prose ─── */
  .prose { color: var(--text-2); font-size: 1rem; line-height: 1.75; }
  .prose h2, .prose h3, .prose h4 { color: var(--text); }
  .prose p { color: var(--text-2); }
  .prose strong { color: var(--text); font-weight: 600; }

  .prose a {
    color: var(--link);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .prose a:hover { color: var(--link-hover); }

  .prose code {
    font-family: "Menlo", "Monaco", monospace;
    font-size: 0.85em;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.1em 0.35em;
    color: var(--text);
  }

  .prose pre {
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
  }
  .prose pre code { background: none; border: none; padding: 0; font-size: 0.875em; }

  .prose blockquote {
    border-left: 2px solid var(--border-hi);
    padding-left: 1rem;
    color: var(--text-3);
    font-style: italic;
  }

  .prose img  { border-radius: 8px; border: 1px solid var(--border); }
  .prose hr   { border-color: var(--border); border-width: 0 0 1px; }
  .prose ul li::marker, .prose ol li::marker { color: var(--text-4); }

  /* ─── Utilities ─── */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
  }
</style>
