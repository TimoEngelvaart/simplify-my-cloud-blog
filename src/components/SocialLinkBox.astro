---
import { Icon } from "astro-icon/components";
import type { SocialLink } from "../types/config";

type Props = SocialLink;
const { title, url, icon, external } = Astro.props;
---

<a
  href={url}
  class="sbox"
  target={external ? "_blank" : "_self"}
  rel={external ? "noopener noreferrer" : undefined}
>
  <Icon name={icon} width={18} height={18} class="sbox-icon" />
  <span class="sbox-title">{title}</span>
  <span class="sbox-arrow">↗</span>
</a>

<style>
  .sbox {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-subtle);
    color: var(--text-2);
    font-size: 0.875rem;
    font-weight: 500;
    transition: border-color 0.12s, background 0.12s;
  }
  .sbox:hover { border-color: var(--border-hi); background: var(--bg-raised); }

  .sbox-icon { color: var(--text-3); flex-shrink: 0; }
  .sbox-title { flex: 1; color: var(--text); }
  .sbox-arrow { color: var(--text-4); font-size: 0.75rem; }
</style>
